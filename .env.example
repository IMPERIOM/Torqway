# =============================================================================
# BoxSpace Containers — Environment variables
# Copy this file to `.env.local` and fill in the values.
# =============================================================================

# --- Supabase (required) -----------------------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public key — either the legacy "anon" JWT or a modern publishable key
# (format: sb_publishable_...). Safe to expose to the browser; RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Bypasses RLS. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# --- Site --------------------------------------------------------------------
# Public base URL of the deployed site (used for SEO / Open Graph / canonicals).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (Phase 3 — quote/invoice notifications) ---------------------------
# Provider TBD (Resend recommended). Leave blank until Phase 3.
RESEND_API_KEY=
# Address that customer confirmations + admin notifications are sent from/to.
EMAIL_FROM=
ADMIN_NOTIFICATION_EMAIL=
